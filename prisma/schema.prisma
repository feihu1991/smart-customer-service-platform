generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 订阅等级枚举
enum SubscriptionTier {
  free
  basic
  pro
  enterprise
}

// 订阅状态枚举
enum SubscriptionStatus {
  active      // 有效
  cancelled   // 已取消
  expired     // 已过期
  pending     // 待生效
}

// 用户
model User {
  id                 String         @id @default(cuid())
  phone              String         @unique
  password           String?
  name               String         @default("新用户")
  avatar             String?
  subscriptionTier   SubscriptionTier @default(free)
  planId             String?        // 当前订阅的套餐ID（关联SubscriptionPlan）
  subscriptionStatus SubscriptionStatus @default(active) // 订阅状态
  subscriptionExpireAt DateTime?    // 订阅到期时间
  dailyUsageCount    Int            @default(0)
  lastUsageDate      DateTime       @default(now())
  dailyLimit         Int            @default(3)       // 每日限制次数，免费用户3次
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  subscriptions      Subscription[]
  sessions           UserSession[]
  shops              Shop[]
}

// 用户会话（用于JWT token管理）
model UserSession {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  deviceInfo   String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 订阅记录
model Subscription {
  id               String            @id @default(cuid())
  userId           String
  tier             SubscriptionTier
  status           String            @default("active")  // active, cancelled, expired
  startDate        DateTime          @default(now())
  endDate          DateTime?
  autoRenew        Boolean           @default(true)
  dailyLimit       Int               @default(3)        // 该套餐的每日限制次数
  price            Float             @default(0)        // 价格（分）
  transactionId    String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 店铺（支持多店铺：每个用户可有多个店铺）
model Shop {
  id           String        @id @default(cuid())
  userId       String        // 店铺所属用户ID
  name         String        // 店铺名称
  platform     String        @default("taobao") // 平台：taobao/jd/pdd
  shopId       String?       // 平台店铺ID（模拟）
  accessToken  String?       // 平台授权Token（模拟）
  logo         String?
  status       String        @default("active") // active/inactive
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews      Review[]
  orders       Order[]
  chatSessions ChatSession[]
  products     Product[]
}

// 商品
model Product {
  id        String   @id @default(cuid())
  shopId    String
  title     String
  imageUrl  String?
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  reviews   Review[]
  orders    Order[]
  shop      Shop     @relation(fields: [shopId], references: [id])
}

// 评价
model Review {
  id              String        @id @default(cuid())
  shopId          String
  productId       String
  orderId         String?
  buyerName       String
  buyerAvatar     String?
  rating          Int
  content         String
  images          String?
  sentiment       String        @default("neutral")
  category        String?
  replyStatus     String        @default("pending")
  replySentAt     DateTime?
  recoveryStatus  String        @default("pending") // pending/contacted/recovered/failed
  recoveredAt     DateTime?
  buyerFeedback   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  replies         ReviewReply[]
  shop            Shop          @relation(fields: [shopId], references: [id])
  product         Product       @relation(fields: [productId], references: [id])
}

// 评价回复
model ReviewReply {
  id        String   @id @default(cuid())
  reviewId  String
  content   String
  type      String   @default("ai_generated")
  isSent    Boolean  @default(false)
  aiScore   Float?
  createdAt DateTime @default(now())
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  quality   ReplyQuality?
}

// 订单
model Order {
  id               String   @id @default(cuid())
  shopId           String
  productId        String
  orderNo          String   @unique
  buyerName        String
  buyerPhone       String?
  amount           Float
  status           String   @default("pending")
  address          String?
  logisticsNo      String?
  logisticsCompany String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  shop             Shop     @relation(fields: [shopId], references: [id])
  product          Product  @relation(fields: [productId], references: [id])
}

// 聊天会话
model ChatSession {
  id          String        @id @default(cuid())
  shopId      String
  buyerName   String
  buyerAvatar String?
  status      String        @default("active")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  messages    ChatMessage[]
  shop        Shop          @relation(fields: [shopId], references: [id])
}

// 聊天消息
model ChatMessage {
  id        String       @id @default(cuid())
  sessionId String
  sender    String
  content   String
  type      String       @default("text")
  createdAt DateTime     @default(now())
  session   ChatSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// 回复模板
model ReplyTemplate {
  id         String   @id @default(cuid())
  name       String
  category   String
  content    String
  usageCount Int      @default(0)
  isBuiltIn  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// 回复质量评估
model ReplyQuality {
  id              String   @id @default(cuid())
  replyId         String   @unique
  score           Float    // 综合评分 0-100
  relevance       Float    // 相关性 0-100
  politeness      Float    // 礼貌度 0-100
  professionalism Float    // 专业性 0-100
  recoveryPotential Float  // 挽回潜力 0-100
  isLowQuality    Boolean  @default(false) // 是否标记为低质量
  evaluatedAt     DateTime @default(now())
  reply           ReviewReply @relation(fields: [replyId], references: [id], onDelete: Cascade)
}

// 订阅套餐（可配置的套餐定义）
model SubscriptionPlan {
  id            String   @id @default(cuid())
  tier          SubscriptionTier @unique  // 关联枚举：free, basic, pro, enterprise
  name          String   // 套餐名称
  description   String?  // 套餐描述
  price         Float    @default(0)  // 价格（元/月）
  priceYearly   Float?   // 年付价格（元/年）
  dailyLimit    Int      @default(3)  // 每日AI回复次数限制
  shopLimit     Int      @default(1)  // 店铺数量限制
  aiReplyLimit  Int      @default(3)  // AI回复次数（-1表示无限）
  templateLimit Int      @default(10) // 可用模板数量
  features      String   // JSON格式的功能列表
  limits        String?  // JSON格式的其他限制
  isActive      Boolean  @default(true)  // 是否启用
  sortOrder     Int      @default(0)  // 排序顺序
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// 订阅套餐（可配置的套餐定义）
model SubscriptionPlan {
  id            String   @id @default(cuid())
  tier          SubscriptionTier @unique  // 关联枚举：free, basic, pro, enterprise
  name          String   // 套餐名称
  description   String?  // 套餐描述
  price         Float    @default(0)  // 价格（元/月）
  priceYearly   Float?   // 年付价格（元/年）
  dailyLimit    Int      @default(3)  // 每日AI回复次数限制
  shopLimit     Int      @default(1)  // 店铺数量限制
  aiReplyLimit  Int      @default(3)  // AI回复次数（-1表示无限）
  templateLimit Int      @default(10) // 可用模板数量
  features      String   // JSON格式的功能列表
  limits        String?  // JSON格式的其他限制
  isActive      Boolean  @default(true)  // 是否启用
  sortOrder     Int      @default(0)  // 排序顺序
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// 订阅套餐（可配置的套餐定义）
model SubscriptionPlan {
  id            String   @id @default(cuid())
  tier          SubscriptionTier @unique  // 关联枚举：free, basic, pro, enterprise
  name          String   // 套餐名称
  description   String?  // 套餐描述
  price         Float    @default(0)  // 价格（元/月）
  priceYearly   Float?   // 年付价格（元/年）
  dailyLimit    Int      @default(3)  // 每日AI回复次数限制
  shopLimit     Int      @default(1)  // 店铺数量限制
  aiReplyLimit  Int      @default(3)  // AI回复次数（-1表示无限）
  templateLimit Int      @default(10) // 可用模板数量
  features      String   // JSON格式的功能列表
  limits        String?  // JSON格式的其他限制
  isActive      Boolean  @default(true)  // 是否启用
  sortOrder     Int      @default(0)  // 排序顺序
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
